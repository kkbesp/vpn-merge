#!/bin/bash
# VPN Manager — подписки, пинг-таргеты, WARP-домены

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG="$SCRIPT_DIR/vpn-config.json"
GENERATOR="$SCRIPT_DIR/vpn-generate.py"
WORKER_DIR="$SCRIPT_DIR/worker"
DENO_DIR="$SCRIPT_DIR/deno-worker"

G='\033[32m' R='\033[31m' Y='\033[33m' C='\033[36m' M='\033[35m'
B='\033[1m' D='\033[2m' N='\033[0m'

if [[ ! -f "$CONFIG" ]]; then
  echo -e "${R}Конфиг не найден. Запусти ./install.sh${N}"
  exit 1
fi

# Читаем worker URLs из конфига
WORKER_URLS=$(python3 -c "
import json;d=json.load(open('$CONFIG'))
urls=d.get('worker_urls',[]);
if not urls: u=d.get('worker_url',''); urls=[u] if u else []
print('\n'.join(urls))
" 2>/dev/null)
WORKER_URL=$(echo "$WORKER_URLS" | head -1)
if [[ -z "$WORKER_URL" ]]; then
  echo -e "${R}worker_urls не задан. Запусти ./install.sh${N}"
  exit 1
fi

# ─── Спиннер ───
spin_pid=""
spinner() {
  local frames=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
  local msg="$1" i=0
  while true; do
    printf "\r  ${C}${frames[$i]}${N} ${msg}" >&2
    i=$(( (i + 1) % ${#frames[@]} ))
    sleep 0.08
  done
}
start_spin() { spinner "$1" & spin_pid=$!; disown $spin_pid; }
stop_spin() { [[ -n "$spin_pid" ]] && kill "$spin_pid" 2>/dev/null; spin_pid=""; printf "\r\033[K" >&2; }

# ─── UI ───
hr() { echo -e "${D}  ──────────────────────────────────────────${N}"; }

show() {
  clear
  echo ""
  echo -e "  ${B}${C}⚡ VPN Manager${N}"
  hr

  echo -e "\n  ${B}📡 Подписки${N}"
  local subs=$(python3 -c "
import json;d=json.load(open('$CONFIG'))
for i,s in enumerate(d['subscriptions']):
  domain=s.split('//')[1].split('/')[0] if '//' in s else s
  print(f'     ${G}{i+1}${N}  {domain}  ${D}{s}${N}')
" 2>/dev/null)
  [[ -z "$subs" ]] && echo -e "     ${D}(пусто — добавь через 1)${N}" || echo -e "$subs"

  echo -e "\n  ${B}🎯 Пинг-таргеты${N}"
  local pings=$(python3 -c "
import json;d=json.load(open('$CONFIG'))
icons={'telegram':'💬','claude':'🤖','google':'🟢','instagram':'📸','gemini':'✨','meet':'📹','youtube':'▶️','twitter':'🐦','x.com':'🐦'}
for i,s in enumerate(d['ping_targets']):
  domain=s.split('//')[1].split('/')[0] if '//' in s else s
  icon='🌐'
  for k,v in icons.items():
    if k in s.lower(): icon=v; break
  print(f'     ${G}{i+1}${N}  {icon} {domain}')
" 2>/dev/null)
  [[ -z "$pings" ]] && echo -e "     ${D}(пусто)${N}" || echo -e "$pings"

  echo -e "\n  ${B}🔒 WARP-домены${N} ${D}(через Cloudflare, обход гео-блоков)${N}"
  local warps=$(python3 -c "
import json;d=json.load(open('$CONFIG'))
icons={'gemini':'✨','openai':'🤖','chatgpt':'🤖','claude':'🧠','copilot':'🛠','midjourney':'🎨','instagram':'📸','netflix':'🎬','spotify':'🎵'}
for i,s in enumerate(d.get('warp_domains',[])):
  icon='🔒'
  for k,v in icons.items():
    if k in s.lower(): icon=v; break
  print(f'     ${G}{i+1}${N}  {icon} {s}')
" 2>/dev/null)
  [[ -z "$warps" ]] && echo -e "     ${D}(пусто)${N}" || echo -e "$warps"

  hr
  echo -e "\n  ${B}🔗 Shadowrocket (зеркала)${N}"
  local i=1
  echo "$WORKER_URLS" | while read -r wurl; do
    [[ -z "$wurl" ]] && continue
    local domain=$(echo "$wurl" | sed 's|https\?://||' | sed 's|/.*||')
    echo -e "     ${C}${i}${N}  ${domain}"
    echo -e "        /sub  ${G}${wurl}/sub${N}"
    echo -e "        /conf ${G}${wurl}/conf${N}"
    echo -e "        /ping ${G}${wurl}/ping${N}"
    i=$((i+1))
  done
  echo ""
  hr
}

menu() {
  echo ""
  echo -e "  ${C}1${N} добавить подписку      ${C}5${N} ${B}деплой${N} 🚀"
  echo -e "  ${C}2${N} удалить подписку       ${C}6${N} тест пинга"
  echo -e "  ${C}3${N} добавить пинг-таргет   ${C}7${N} добавить WARP-домен"
  echo -e "  ${C}4${N} удалить пинг-таргет    ${C}8${N} удалить WARP-домен"
  echo -e "  ${C}0${N} выход"
  echo ""
}

# ─── Подписки ───
add_sub() {
  echo ""; read -rp "  URL подписки: " url; [[ -z "$url" ]] && return

  # Проверяем подписку перед добавлением
  start_spin "Проверяю подписку..."
  local check_result
  check_result=$(python3 -c "
import base64, urllib.request, sys, json

url = '''$url'''
try:
    req = urllib.request.Request(url, headers={
        'User-Agent': 'Shadowrocket/2070 CFNetwork/1568.100.1',
        'Accept-Encoding': 'identity',
    })
    resp = urllib.request.urlopen(req, timeout=10)
    raw = resp.read()
    if len(raw) == 0:
        print('ERROR:Подписка вернула пустой ответ')
        sys.exit(1)

    # Декодируем base64
    try:
        decoded = base64.b64decode(raw).decode('utf-8', errors='replace')
    except:
        decoded = raw.decode('utf-8', errors='replace')

    lines = [l for l in decoded.strip().split('\n') if '://' in l]
    if len(lines) == 0:
        print('ERROR:Не найдено серверов')
        sys.exit(1)

    # Считаем типы транспорта
    transports = {}
    problems = []
    for line in lines:
        if 'type=xhttp' in line:
            transports['xhttp'] = transports.get('xhttp', 0) + 1
        elif 'type=tcp' in line:
            transports['tcp'] = transports.get('tcp', 0) + 1
        elif 'type=ws' in line:
            transports['ws'] = transports.get('ws', 0) + 1
        elif 'type=grpc' in line:
            transports['grpc'] = transports.get('grpc', 0) + 1
        elif 'type=h2' in line:
            transports['h2'] = transports.get('h2', 0) + 1
        else:
            transports['other'] = transports.get('other', 0) + 1

    total = len(lines)
    xhttp = transports.get('xhttp', 0)

    if xhttp > 0 and xhttp == total:
        print(f'WARN:Все {total} серверов используют xhttp — может крашить Shadowrocket на macOS')
    elif xhttp > 0:
        print(f'WARN:{total} серверов ({xhttp} xhttp — могут крашить SR на macOS, {total-xhttp} остальных ок)')
    else:
        print(f'OK:{total} серверов')

    info = ', '.join(f'{v} {k}' for k, v in sorted(transports.items(), key=lambda x: -x[1]))
    print(f'INFO:{info}')

except Exception as e:
    print(f'ERROR:{e}')
    sys.exit(1)
" 2>&1)
  stop_spin

  # Парсим результат
  local has_error=0
  local has_warn=0
  while IFS= read -r line; do
    case "$line" in
      ERROR:*) echo -e "  ${R}✗${N} ${line#ERROR:}"; has_error=1 ;;
      WARN:*)  echo -e "  ${Y}⚠${N} ${line#WARN:}"; has_warn=1 ;;
      OK:*)    echo -e "  ${G}✓${N} ${line#OK:}" ;;
      INFO:*)  echo -e "  ${D}  ${line#INFO:}${N}" ;;
    esac
  done <<< "$check_result"

  if [[ "$has_error" == "1" ]]; then
    echo -e "  ${R}Подписка не добавлена${N}"
    sleep 1
    return
  fi

  if [[ "$has_warn" == "1" ]]; then
    echo ""
    read -rp "  Добавить всё равно? (y/n): " confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" && "$confirm" != "д" ]] && return
  fi

  python3 -c "
import json;d=json.load(open('$CONFIG'))
d['subscriptions'].append('''$url''')
json.dump(d,open('$CONFIG','w'),indent=2,ensure_ascii=False)"
  echo -e "  ${G}✓${N} Добавлено"; sleep 0.5
}

del_sub() {
  echo ""; read -rp "  Номер: " n; [[ -z "$n" ]] && return
  python3 -c "
import json;d=json.load(open('$CONFIG'))
i=int('$n')-1
if 0<=i<len(d['subscriptions']):
  d['subscriptions'].pop(i);json.dump(d,open('$CONFIG','w'),indent=2,ensure_ascii=False)
  print('  \033[32m✓\033[0m Удалено')
else: print('  \033[31m✗\033[0m Нет такого номера')"
  sleep 0.5
}

# ─── Пинг ───
add_ping() {
  echo ""
  echo -e "  ${D}Примеры: https://t.me/  https://claude.ai/api/health${N}"
  read -rp "  URL: " url; [[ -z "$url" ]] && return
  python3 -c "
import json;d=json.load(open('$CONFIG'))
d['ping_targets'].append('''$url''')
json.dump(d,open('$CONFIG','w'),indent=2,ensure_ascii=False)"
  echo -e "  ${G}✓${N} Добавлено"; sleep 0.5
}

del_ping() {
  echo ""; read -rp "  Номер: " n; [[ -z "$n" ]] && return
  python3 -c "
import json;d=json.load(open('$CONFIG'))
i=int('$n')-1
if 0<=i<len(d['ping_targets']):
  d['ping_targets'].pop(i);json.dump(d,open('$CONFIG','w'),indent=2,ensure_ascii=False)
  print('  \033[32m✓\033[0m Удалено')
else: print('  \033[31m✗\033[0m Нет такого номера')"
  sleep 0.5
}

# ─── WARP-домены ───
add_warp() {
  echo ""
  echo -e "  ${D}Домен без https:// — например: gemini.google.com${N}"
  read -rp "  Домен: " domain; [[ -z "$domain" ]] && return
  domain=$(echo "$domain" | sed 's|https\?://||' | sed 's|/.*||')
  python3 -c "
import json;d=json.load(open('$CONFIG'))
wd=d.setdefault('warp_domains',[])
if '$domain' not in wd:
  wd.append('$domain');json.dump(d,open('$CONFIG','w'),indent=2,ensure_ascii=False)
  print('  \033[32m✓\033[0m $domain → WARP')
else: print('  \033[33m~\033[0m Уже есть')"
  sleep 0.5
}

del_warp() {
  echo ""; read -rp "  Номер: " n; [[ -z "$n" ]] && return
  python3 -c "
import json;d=json.load(open('$CONFIG'))
wd=d.get('warp_domains',[])
i=int('$n')-1
if 0<=i<len(wd):
  removed=wd.pop(i);d['warp_domains']=wd
  json.dump(d,open('$CONFIG','w'),indent=2,ensure_ascii=False)
  print(f'  \033[32m✓\033[0m Удалено: {removed}')
else: print('  \033[31m✗\033[0m Нет такого номера')"
  sleep 0.5
}

# ─── Деплой ───
deploy() {
  echo ""

  start_spin "Обновляю WARP-ключи + генерирую конфиг..."
  local gen_output
  gen_output=$(python3 "$GENERATOR" 2>&1)
  stop_spin
  echo "$gen_output" | while read -r line; do echo "  $line"; done

  # Deno Deploy
  if [[ -f "$WORKER_DIR/deno-worker.ts" ]]; then
    mkdir -p "$DENO_DIR"
    cp "$WORKER_DIR/deno-worker.ts" "$DENO_DIR/main.ts"

    local deno_app=$(python3 -c "
import json;d=json.load(open('$CONFIG'))
urls=d.get('worker_urls',[])
for u in urls:
  if 'deno' in u:
    print(u.replace('https://','').split('.')[0])
    break
" 2>/dev/null)

    if [[ -n "$deno_app" ]]; then
      start_spin "Деплою на Deno Deploy..."
      local deno_output
      deno_output=$(cd "$DENO_DIR" && deno deploy --app "$deno_app" --prod 2>&1)
      stop_spin
      if echo "$deno_output" | grep -q "Successfully deployed"; then
        echo -e "  ${G}✓${N} Deno Deploy задеплоен"
      else
        echo -e "  ${Y}⚠${N} Deno: $(echo "$deno_output" | grep -i "error\|fail\|✗" | tail -1)"
      fi
    else
      echo -e "  ${Y}⚠${N} Deno Deploy не настроен (запусти ./install.sh)"
    fi
  fi

  # Проверка
  sleep 3
  echo ""
  echo "$WORKER_URLS" | while read -r wurl; do
    [[ -z "$wurl" ]] && continue
    local domain=$(echo "$wurl" | sed 's|https\?://||' | sed 's|/.*||')
    local status=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 "${wurl}/ping" 2>/dev/null)
    local count=$(curl -s --max-time 5 "${wurl}/sub" | base64 -d 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$status" == "204" ]]; then
      echo -e "  ${G}✓${N} ${domain} → ${count} серверов"
    else
      echo -e "  ${Y}⚠${N} ${domain} → HTTP ${status}"
    fi
  done

  echo ""
  echo -e "  ${G}${B}Всё готово!${N} 🎉"
}

# ─── Тест пинга ───
test_ping() {
  echo ""
  start_spin "Тестирую /ping..."
  local status
  status=$(curl -s -o /dev/null -w "%{http_code}" "${WORKER_URL}/ping" 2>/dev/null)
  stop_spin

  if [[ "$status" == "204" ]]; then
    echo -e "  ${G}✓${N} Все сервисы доступны"
  elif [[ "$status" == "502" ]]; then
    echo -e "  ${R}✗${N} Один или несколько сервисов недоступны"
  else
    echo -e "  ${Y}⚠${N} Ответ: ${status}"
  fi

  echo ""
  python3 -c "
import json;d=json.load(open('$CONFIG'))
for s in d['ping_targets']:
  domain=s.split('//')[1].split('/')[0] if '//' in s else s
  print(domain)" 2>/dev/null | while read -r domain; do
    start_spin "Проверяю ${domain}..."
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 "https://${domain}/" 2>/dev/null)
    stop_spin
    if [[ "$code" -gt 0 && "$code" -lt 400 ]]; then
      echo -e "  ${G}✓${N} ${domain} → ${code}"
    elif [[ "$code" -ge 400 ]]; then
      echo -e "  ${Y}~${N} ${domain} → ${code} ${D}(доступен)${N}"
    else
      echo -e "  ${R}✗${N} ${domain} → недоступен"
    fi
  done
  sleep 0.5
}

# ─── Main ───
while true; do
  show
  menu
  read -rp "  > " choice
  case $choice in
    1) add_sub ;;
    2) del_sub ;;
    3) add_ping ;;
    4) del_ping ;;
    5) deploy; read -rp "  Enter для продолжения..." ;;
    6) test_ping; read -rp "  Enter для продолжения..." ;;
    7) add_warp ;;
    8) del_warp ;;
    0|q) clear; echo -e "\n  ${C}👋${N}\n"; exit 0 ;;
    *) echo -e "  ${D}?${N}"; sleep 0.3 ;;
  esac
done
